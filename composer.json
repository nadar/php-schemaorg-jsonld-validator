{
    "name": "nadar/php-schemaorg-jsonld-validator",
    "description": "A PHP library that validates JSON-LD structured data against the schema.org vocabulary.",
    "type": "library",
    "license": "MIT",
    "keywords": ["schema.org", "json-ld", "jsonld", "validator", "structured-data", "seo"],
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nadar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nadar\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
